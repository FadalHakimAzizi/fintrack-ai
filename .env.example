# ─── Supabase (required) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── App URL (required for email links) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── n8n Integration ───────────────────────────────────────────────────────
# Random 32+ char hex string — must match what's set in n8n workflows
N8N_WEBHOOK_SECRET=generate_random_hex_here
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_OCR_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/fintrack-ocr

# ─── OpenRouter AI (required for AI Advisor + Semantic Search) ─────────────
OPENROUTER_API_KEY=sk-or-v1-your_key_here
# Free model: openai/gpt-oss-120b:free
# Better quality: openai/gpt-4o-mini, anthropic/claude-haiku-4-5
OPENROUTER_MODEL=openai/gpt-oss-120b:free
