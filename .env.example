# ─── Supabase (required) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── App URL (required for email links) ────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ─── n8n Integration ───────────────────────────────────────────────────────
# Random 32+ char hex string — must match what's set in n8n workflows
N8N_WEBHOOK_SECRET=generate_random_hex_here
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_OCR_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/fintrack-ocr

# ─── Groq AI (AI Advisor, receipt vision, semantic search) ────────────────
# Two keys for automatic fallback: if the primary hits a rate/credit limit,
# requests transparently retry on the backup. Get keys at console.groq.com/keys
GROQ_API_KEY=gsk_your_primary_key_here
GROQ_API_KEY_BACKUP=gsk_your_backup_key_here
# Optional overrides (defaults shown):
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Embeddings / RAG ──────────────────────────────────────────────────────
# Powers semantic retrieval over the FULL transaction history in the AI chat.
# After configuring: run migration supabase/migrations/005_rag_embeddings.sql,
# then backfill via the "Indeks transaksi untuk AI" button in Settings.
#
# DEV (default) — local Ollama + Qwen3 (free, private):
#   ollama pull qwen3-embedding:0.6b   (keep Ollama running)
# EMBEDDINGS_PROVIDER=ollama
# EMBEDDINGS_BASE_URL=http://localhost:11434
# EMBEDDINGS_MODEL=qwen3-embedding:0.6b
#
# PRODUCTION (Vercel can't reach your localhost) — pick a 1024-dim cloud model
# so the pgvector schema is unchanged. Examples:
#   Voyage (200M free tokens):
#     EMBEDDINGS_PROVIDER=voyage
#     EMBEDDINGS_BASE_URL=https://api.voyageai.com/v1
#     EMBEDDINGS_MODEL=voyage-3.5-lite
#     EMBEDDINGS_API_KEY=pa-...
#   Jina (free tier):
#     EMBEDDINGS_PROVIDER=jina
#     EMBEDDINGS_BASE_URL=https://api.jina.ai/v1
#     EMBEDDINGS_MODEL=jina-embeddings-v3
#     EMBEDDINGS_API_KEY=jina_...
#
# Shared (defaults shown):
# EMBEDDINGS_DIM=1024              # must match the pgvector column
# EMBEDDINGS_DISABLED=0            # set to 1 to turn RAG off (chat still works)
# Gap-based retrieval tuning — retrieve only when the best hit clearly stands
# out, so generic questions return nothing instead of a fixed N:
# EMBEDDINGS_MATCH_FLOOR=0.45      # candidate-pool floor
# EMBEDDINGS_MATCH_THRESHOLD=0.58  # best hit must clear this, else retrieve 0
# EMBEDDINGS_REL_MARGIN=0.1        # keep rows within this of the best hit
# EMBEDDINGS_MAX_MATCHES=6         # hard cap on retrieved rows
