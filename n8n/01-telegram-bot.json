      "parameters": {
        "jsCode": "const binary = $input.item.binary?.data;\nif (!binary) throw new Error('No binary data from download step');\nreturn [{\n  json: {},\n  binary: {\n    data: {\n      ...binary,\n      fileName: 'voice.ogg',\n      mimeType: 'audio/ogg',\n      fileExtension: 'ogg'\n    }\n  }\n}];"
      },
