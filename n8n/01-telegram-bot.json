    {
      "parameters": {
        "jsCode": "const raw = $input.first().json?.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/```json\\n?|```/g, '').trim();\n\nlet parsed;\ntry { parsed = JSON.parse(cleaned); } catch (err) { return [{ json: { _error: 'Could not parse LLM output', raw, cleaned } }]; }\n\nif (!parsed || typeof parsed.amount !== 'number' || !parsed.transaction_type) {\n  return [{ json: { _error: 'LLM output missing required fields', parsed } }];\n}\n\nconst userId = $('Resolve User').first().json.user_id;\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\n\nreturn [{ json: {\n  user_id: userId,\n  transaction_type: parsed.transaction_type,\n  amount: parsed.amount,\n  currency: parsed.currency || 'IDR',\n  transaction_date: new Date().toISOString().slice(0, 10),\n  merchant_name: parsed.merchant_name || null,\n  item_name: parsed.item_name || null,\n  category: parsed.category || null,\n  payment_method: parsed.payment_method || null,\n  notes: parsed.notes || null,\n  source_channel: 'telegram',\n  source_reference: `tg:${chatId}:${$('Telegram Trigger').item.json.message.message_id}`,\n  confidence_score: typeof parsed.confidence_score === 'number' ? parsed.confidence_score : 0.7,\n  parsed_status: 'parsed'\n} }];"
      },
