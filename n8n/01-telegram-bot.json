      "id": "cf671cde-1ed7-4b67-b41d-df0e088959a7",
      "name": "Vision LLM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3520,
        912
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "H5ckmlGmfkJgIK4Y",
          "name": "groq"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json?.choices?.[0]?.message?.content || '';\nconst cleaned = raw.replace(/```json\\n?|```/g, '').trim();\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (err) {\n  return [{ json: { _error: 'Could not parse vision output', raw } }];\n}\n\nif (typeof parsed.amount !== 'number' || parsed.amount <= 0 || !parsed.transaction_type) {\n  return [{ json: { _error: 'No valid amount detected from photo', parsed } }];\n}\n\nconst userId = $('Resolve User').first().json.user_id;\nconst chatId = $('Telegram Trigger').item.json.message.chat.id;\nconst msgId = $('Telegram Trigger').item.json.message.message_id;\n\nconst payload = {\n  user_id: userId,\n  transaction_type: parsed.transaction_type,\n  amount: parsed.amount,\n  currency: parsed.currency || 'IDR',\n  transaction_date: parsed.transaction_date || new Date().toISOString().slice(0, 10),\n  merchant_name: parsed.merchant_name || null,\n  item_name: parsed.item_name || null,\n  category: parsed.category || null,\n  payment_method: parsed.payment_method || null,\n  notes: parsed.notes || ($('Telegram Trigger').item.json.message.caption || null),\n  source_channel: 'telegram',\n  source_reference: `tg:${chatId}:${msgId}:photo`,\n  confidence_score: typeof parsed.confidence_score === 'number' ? parsed.confidence_score : 0.6,\n  parsed_status: 'parsed'\n};\n\nreturn [{ json: payload }];"
      },
      "id": "3d6d021a-1144-4649-aed1-5bdfd54bd99e",
      "name": "Build Photo Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3760,
        912
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = $('Telegram Trigger').item.json.message.text || '';\n\nconst body = {\n  model: 'llama-3.3-70b-versatile',\n  temperature: 0.1,\n  messages: [\n    {\n      role: 'system',\n      content: 'You are a finance data extractor. Extract transaction data from user messages in Indonesian or English. Respond with ONLY a JSON object, no prose, no markdown fences.\\n\\nSchema:\\n{\\n  \"transaction_type\": \"income\" | \"expense\",\\n  \"amount\": number,\\n  \"currency\": \"IDR\",\\n  \"merchant_name\": \"string or null\",\\n  \"item_name\": \"string or null\",\\n  \"category\": \"Groceries|Dining|Transportation|Utilities|Entertainment|Shopping|Health|Other|Salary|Freelance|Investment\",\\n  \"payment_method\": \"string or null\",\\n  \"notes\": \"string or null\",\\n  \"confidence_score\": 0.0\\n}\\n\\nRules:\\n- \"habis\", \"keluar\", \"beli\", \"bayar\" -> expense\\n- \"terima\", \"dapet\", \"gajian\", \"masuk\" -> income\\n- \"rb\" or \"k\" = x1000, \"jt\" = x1_000_000\\n- Return ONLY the JSON object.'\n    },\n    {\n      role: 'user',\n      content: text\n    }\n  ]\n};\n\nreturn [{ json: { body: JSON.stringify(body) } }];"
      },
