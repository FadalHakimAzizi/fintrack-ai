    {
      "parameters": {
        "jsCode": "const text = $json.text || '';\nif (!text) throw new Error('Empty transcription from Whisper');\n\nconst body = {\n  model: 'llama-3.3-70b-versatile',\n  temperature: 0.1,\n  messages: [\n    {\n      role: 'system',\n      content: 'You are a finance data extractor. Extract transaction data from user messages in Indonesian or English. Respond with ONLY a JSON object, no prose, no markdown fences.\\n\\nSchema:\\n{\\n  \"transaction_type\": \"income\" | \"expense\",\\n  \"amount\": number,\\n  \"currency\": \"IDR\",\\n  \"merchant_name\": \"string or null\",\\n  \"item_name\": \"string or null\",\\n  \"category\": \"Groceries|Dining|Transportation|Utilities|Entertainment|Shopping|Health|Other|Salary|Freelance|Investment\",\\n  \"payment_method\": \"string or null\",\\n  \"notes\": \"string or null\",\\n  \"confidence_score\": 0.0\\n}\\n\\nRules:\\n- \"habis\", \"keluar\", \"beli\", \"bayar\" -> expense\\n- \"terima\", \"dapet\", \"gajian\", \"masuk\" -> income\\n- \"rb\" or \"k\" = x1000, \"jt\" = x1_000_000\\n- Return ONLY the JSON object.'\n    },\n    { role: 'user', content: text }\n  ]\n};\n\nreturn [{ json: { body: JSON.stringify(body), _transcription: text } }];"
