      "id": "bc25e7b0-e1d5-46ae-adfe-affec077653e",
      "name": "Get Telegram File",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        3040,
        912
      ]
    },
    {
      "parameters": {
        "jsCode": "const filePath = $json.result.file_path;\nconst caption = $('Get File Path').first().json.caption || '';\nconst imageUrl = 'https://api.telegram.org/file/bot8588113276:AAFJsjox4vMwmujaCP3t9F6MMPmXMOrhs1Q/' + filePath;\n\nconst body = {\n  model: 'meta-llama/llama-4-scout-17b-16e-instruct',\n  temperature: 0.1,\n  messages: [{\n    role: 'user',\n    content: [\n      {\n        type: 'text',\n        text: 'You are a receipt/invoice OCR extractor. Return ONLY a JSON object, no prose, no markdown fences.\\n\\n' +\n          (caption ? 'User caption: \"' + caption + '\"\\n\\n' : '') +\n          'Schema:\\n{\"transaction_type\":\"income|expense\",\"amount\":number,\"currency\":\"IDR\",\"transaction_date\":\"YYYY-MM-DD or null\",\"merchant_name\":\"string or null\",\"item_name\":\"string or null\",\"category\":\"Groceries|Dining|Transportation|Utilities|Entertainment|Shopping|Health|Other|Salary|Freelance|Investment\",\"payment_method\":\"string or null\",\"invoice_number\":\"string or null\",\"notes\":\"string or null\",\"confidence_score\":0.0}\\n\\nRules:\\n- Most receipts = expense. Only income if refund/credit.\\n- amount = grand total after tax/discount\\n- Return ONLY the JSON object.'\n      },\n      {\n        type: 'image_url',\n        image_url: { url: imageUrl }\n      }\n    ]\n  }]\n};\n\nreturn [{ json: { body: JSON.stringify(body) } }];"
      },
      "id": "118eb45f-117b-4c09-a1f1-e8ecc0f31978",
      "name": "Build Vision Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3280,
        912
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json.body }}",
        "options": {
          "timeout": 90000
        }
